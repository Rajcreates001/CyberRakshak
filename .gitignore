# ------------------------------
# Runtime data generated by pipelines
# Keep only .gitkeep placeholders
# ------------------------------
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/delta/*
!data/delta/.gitkeep

data/quarantine/*
!data/quarantine/.gitkeep

data/reports/*
!data/reports/.gitkeep

data/removed/*
!data/removed/.gitkeep

data/diagrams/*
!data/diagrams/.gitkeep

data/stream_output/*
!data/stream_output/.gitkeep
!data/stream_output/_checkpoint/
!data/stream_output/delta_stream/
!data/stream_output/metrics/
!data/stream_output/reports/
!data/stream_output/warehouse/

data/stream_output/_checkpoint/*
!data/stream_output/_checkpoint/.gitkeep

data/stream_output/delta_stream/*
!data/stream_output/delta_stream/.gitkeep

data/stream_output/metrics/*
!data/stream_output/metrics/.gitkeep

data/stream_output/reports/*
!data/stream_output/reports/.gitkeep

data/stream_output/warehouse/*
!data/stream_output/warehouse/.gitkeep

# Logs
logs/*
!logs/.gitkeep

# ------------------------------
# Datasets
# Keep folder scaffold only
# ------------------------------
datasets/*
!datasets/cybersecurity/
!datasets/cybersecurity/.gitkeep
datasets/cybersecurity/dataset.csv

